{
  "explicit_parameters": {
    "dataset_name": "cifar-10",
    "image_size": 32,
    "batch_size_per_rank": 128,
    "warmup_epochs": 10,
    "epochs": 1000,
    "early_stop_patience": 15,
    "compression_ratio": 3.0,
    "noise_sigma_max_angle": 80,
    "vit_enc_model_size": "small",
    "vit_dec_model_size": "small",
    "vit_enc_latent_mlp_mixer_depth": 2,
    "vit_dec_latent_mlp_mixer_depth": 2,
    "affine_latent_mlp_mixer": true,
    "pixel_head_type": "conv",
    "ckpt_save_interval": 100,
    "lat_con_loss_weight": 0.1,
    "pix_recon_dist_loss_weight": 1.0,
    "pix_recon_perc_loss_weight": 1.0,
    "pix_con_dist_loss_weight": 0.5,
    "pix_con_perc_loss_weight": 0.5
  },
  "default_parameters": {
    "dev_dir": "workspace",
    "out_dir": "experiments",
    "data_dir": "datasets",
    "log_interval": 100,
    "vis_interval": 2,
    "crop_mode": "center",
    "flip_image": true,
    "extra_padding": false,
    "rot_degrees": 0,
    "batch_size": 256,
    "weight_decay": 0.0,
    "grad_clip": 1.0,
    "learning_rate": 0.0001,
    "min_lr": 0.000001,
    "encoder_lr_scaler": 0.1,
    "decay_lr": true,
    "latent_resolution": "high",
    "mix_hard_cases": true,
    "mix_hard_cases_prob": 0.1,
    "cond_generator": true,
    "use_ema": true,
    "ema_model_decay": 0.9997,
    "spherify_model": false,
    "in_context_size": 0,
    "halve_model_size": false,
    "dtype": "bfloat16",
    "device_type": "cuda",
    "compile_model": false,
    "force_to_bf16": false,
    "use_activation_checkpointing": false,
    "distance_loss_type": "l1",
    "use_wandb": false,
    "auto_resume": true,
    "perceptual_ckpt_path": "pretrained/lpips"
  },
  "derived_parameters": {
    "note": "These are automatically calculated based on image_size, compression_ratio, and latent_resolution",
    "patch_size": 2,
    "latent_resolution_value": 16,
    "token_channels": 4,
    "num_classes": 10
  },
  "for_inference": {
    "command": "python dataset.py --data_path <path-to-cifar10> --checkpoint workspace/experiments/sphere-small-small-cifar-10-32px/ckpt --image_size 32 --batch_size 128 --vit_enc_model_size small --vit_dec_model_size small --vit_enc_latent_mlp_mixer_depth 2 --vit_dec_latent_mlp_mixer_depth 2 --pixel_head_type conv --compression_ratio 3 --noise_sigma_max_angle 80 --num_classes 10 --num_workers 8"
  }
}
